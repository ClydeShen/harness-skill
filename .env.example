# Eval LLM provider configuration
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Base URL of your local llamacpp-compatible server (include /v1)
EVAL_API_BASE=http://localhost:8080/v1

# Model name for the response provider (used by provider.py)
EVAL_PROVIDER_MODEL=your-model-name

# Model name for the grader/judge (used by grader.py)
# Can be the same model or a different one
EVAL_GRADER_MODEL=your-grader-model-name
